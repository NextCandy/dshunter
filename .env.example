# ===== 必填 =====
# openssl rand -hex 32
SESSION_SECRET=change-me-to-a-long-random-string-32chars-min
# 打开站点需要输入的共享密码
SITE_PASSWORD=your-shared-password
# Cloudflare API Token（Zone:Read/Edit, DNS:Edit, 可选 Account:Read）
# 可留空，登录后在「设置」页 UI 填写保存（加密持久化到 data/secrets.json）
CLOUDFLARE_API_TOKEN=

# ===== NAS 部署 =====
# 容器时区，默认 Asia/Shanghai
TZ=Asia/Shanghai
# docker compose 宿主机映射端口，默认 3000
HOST_PORT=3000
# 内网 http 访问设为 false（否则解锁后 Cookie 不下发会被踢回登录页）；对外 HTTPS 保持 true
COOKIE_SECURE=true

# ===== 注册商（可选，按需填写；未配置的入口会置灰）=====
SPACESHIP_API_KEY=
SPACESHIP_API_SECRET=
DYNADOT_API_KEY=
NAMECHEAP_API_USER=
NAMECHEAP_API_KEY=
NAMECHEAP_USERNAME=
NAMECHEAP_CLIENT_IP=
ALIYUN_ACCESS_KEY_ID=
ALIYUN_ACCESS_KEY_SECRET=
TENCENT_SECRET_ID=
TENCENT_SECRET_KEY=
WEST_USERNAME=
WEST_API_PASSWORD=
