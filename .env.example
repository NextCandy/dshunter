# ---------- Postgres ----------
POSTGRES_DB=domainhunter
POSTGRES_USER=domainhunter
# Generate one:  openssl rand -base64 24
POSTGRES_PASSWORD=changeme-strong-password

# ---------- App ----------
# Generate one:  openssl rand -hex 32
JWT_SECRET=replace-with-32-byte-random-hex-string
# Your public origin (used for OAuth callbacks, cookies). For LAN testing keep localhost.
APP_ORIGIN=http://localhost:3000
APP_PORT=3000

# ---------- AI (optional) ----------
# OpenAI-compatible endpoint. Examples:
#   OpenAI:    https://api.openai.com/v1
#   DeepSeek:  https://api.deepseek.com/v1
#   Ollama:    http://host.docker.internal:11434/v1   (use gateway IP on DSM)
AI_BASE_URL=
AI_API_KEY=
AI_MODEL=gpt-4o-mini

# ---------- Integrations (optional) ----------
SEMRUSH_API_KEY=

# ---------- Registrar domain sync (optional) ----------
# You can also save credentials from Admin -> Registrars; they are encrypted in Postgres.
SPACESHIP_API_KEY=
SPACESHIP_API_SECRET=
PORKBUN_API_KEY=
PORKBUN_SECRET_API_KEY=
GODADDY_API_KEY=
GODADDY_API_SECRET=

# ---------- Google OAuth (optional) ----------
# Leave blank to disable Google sign-in (email/password still works).
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
